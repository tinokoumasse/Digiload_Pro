# Digiload Pro — Central VM Environment Variables
# Copy to .env and fill in before running docker-compose up

# Database
DB_PASSWORD=change_me_strong_password_here
DB_HOST=postgres
DB_PORT=5432
DB_NAME=digiload
DB_USER=digiload

# App
SECRET_KEY=change_me_random_64_char_string_here
FLASK_ENV=production
PORT=5001

# License validation public key (matches private key used to generate license keys)
LICENSE_SECRET=DIGILOAD_LICENSE_SECRET_REPLACE_IN_PRODUCTION

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883

# Clip storage
CLIP_RETENTION_DAYS=30
CLIPS_DIR=/app/clips
REPORTS_DIR=/app/reports

# Your release server (where ZED Boxes download app files from)
RELEASE_BASE_URL=http://localhost:5001
